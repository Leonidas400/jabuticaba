formats/><hidden_columns/><plot_y_axes/><global_filter/></table></browse_table_settings></tab_browse><tab_sql><sql name="SQL 1*">INSERT INTO cis_rules_fortigate 
(cis_id, title, categoria, severity, description, recommendation, status, detail, block, has_or_not_has, pattern, expected_value)
VALUES 
    (
        '7.1', 
        'Syslog Remoto Configurado', 
        'Logging &amp; Monitoring', 
        'High', 
        'Logs devem ser enviados para servidor syslog remoto para centralização e auditoria.', 
        'config log syslogd setting &gt; set status enable &gt; set server &lt;IP&gt;', 
        NULL, 
        'Verifica se o syslog remoto está ativado e com o servidor devidamente preenchido.', 
        'log syslogd setting', 
        'has', 
        'set status\s+enable', 
        'custom_syslog'
    ),
    (
        '7.2', 
        'FortiAnalyzer Configurado', 
        'Logging &amp; Monitoring', 
        'Medium', 
