        'config log fortianalyzer setting &gt; set status enable &gt; set server &lt;IP&gt;', 
        NULL, 
        'Verifica a ativação do FortiAnalyzer no bloco de configuração de logs.', 
        'log fortianalyzer setting', 
        'has', 
        'set status\s+enable', 
        NULL
