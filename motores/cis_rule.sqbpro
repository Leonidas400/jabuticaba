        'log setting', 
        'has', 
        'set local-traffic\s+enable', 
        NULL
    ),
    (
        '7.5', 
        'Log de Eventos do Sistema Habilitado', 
        'Logging &amp; Monitoring', 
        'Medium', 
        'Eventos de sistema (login, alterações de config) devem ser registrados.', 
        'config log setting &gt; set event enable', 
        NULL, 
